#!/home/jesusu/Workspace/agents/crowia/.venv/bin/python3
"""
giselo-pick [--dir] [--save] ["Título"]
Selector de archivo/carpeta usando kdialog (nativo KDE). Imprime path a stdout.
  --dir   seleccionar carpeta
  --save  modo guardar
"""
import os
import shutil
import subprocess
import sys

uid = os.getuid()
env = os.environ.copy()
env.setdefault("WAYLAND_DISPLAY", "wayland-0")
env.setdefault("DISPLAY", ":0")
env.setdefault("XDG_RUNTIME_DIR", f"/run/user/{uid}")
env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")

args = sys.argv[1:]
mode_dir  = "--dir"  in args
mode_save = "--save" in args
args  = [a for a in args if not a.startswith("--")]
title = args[0] if args else ("Seleccionar carpeta" if mode_dir else "Seleccionar archivo")
start = os.path.expanduser("~")

if not shutil.which("kdialog"):
    print("Error: kdialog no encontrado. Instala: sudo pacman -S kdialog", file=sys.stderr)
    sys.exit(1)

if mode_dir:
    cmd = ["kdialog", "--title", title, "--getexistingdirectory", start]
elif mode_save:
    cmd = ["kdialog", "--title", title, "--getsavefilename", start]
else:
    cmd = ["kdialog", "--title", title, "--getopenfilename", start]

result = subprocess.run(cmd, capture_output=True, text=True, env=env)
path = result.stdout.strip()
if result.returncode == 0 and path:
    sys.stdout.write(path)
    sys.stdout.flush()
    sys.exit(0)

sys.exit(1)
