#!/home/jesusu/Workspace/agents/crowia/.venv/bin/python3
"""
pepito-pick [--dir] [--save] ["Título"]
Muestra selector de archivo o carpeta, imprime path a stdout.
  --dir   seleccionar carpeta
  --save  modo guardar
"""
import os
import sys

os.environ.setdefault("WAYLAND_DISPLAY", "wayland-0")
os.environ.setdefault("DISPLAY", ":0")
uid = os.getuid()
os.environ.setdefault("XDG_RUNTIME_DIR", f"/run/user/{uid}")
os.environ.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")
os.environ.setdefault("QT_QPA_PLATFORM", "wayland")

from PyQt6.QtWidgets import QApplication, QFileDialog
from PyQt6.QtCore import Qt

args = sys.argv[1:]
mode_dir = "--dir" in args
mode_save = "--save" in args
args = [a for a in args if not a.startswith("--")]
title = args[0] if args else ("Seleccionar carpeta" if mode_dir else "Seleccionar archivo")
start_dir = str(os.path.expanduser("~"))

app = QApplication(sys.argv)

dlg = QFileDialog()
dlg.setWindowTitle(title)
dlg.setWindowFlags(dlg.windowFlags() | Qt.WindowType.WindowStaysOnTopHint)
dlg.setDirectory(start_dir)

if mode_dir:
    dlg.setFileMode(QFileDialog.FileMode.Directory)
    dlg.setOption(QFileDialog.Option.ShowDirsOnly, True)
elif mode_save:
    dlg.setAcceptMode(QFileDialog.AcceptMode.AcceptSave)
else:
    dlg.setFileMode(QFileDialog.FileMode.ExistingFile)

if dlg.exec() == QFileDialog.DialogCode.Accepted:
    selected = dlg.selectedFiles()
    if selected:
        print(selected[0], end="")
        sys.exit(0)

sys.exit(1)
