#!/home/jesusu/Workspace/agents/crowia/.venv/bin/python3
"""
giselo-askpass
SUDO_ASKPASS helper usando kdialog (nativo KDE). Imprime contraseña a stdout.
"""
import os
import shutil
import subprocess
import sys

uid = os.getuid()
env = os.environ.copy()
env.setdefault("WAYLAND_DISPLAY", "wayland-0")
env.setdefault("DISPLAY", ":0")
env.setdefault("XDG_RUNTIME_DIR", f"/run/user/{uid}")
env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")

prompt = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else "Contraseña sudo:"

if not shutil.which("kdialog"):
    print("Error: kdialog no encontrado.", file=sys.stderr)
    sys.exit(1)

result = subprocess.run(
    ["kdialog", "--title", "Giselo — Autenticación requerida", "--password", prompt],
    capture_output=True, text=True, env=env,
)
text = result.stdout.strip()
if result.returncode == 0 and text is not None:
    sys.stdout.write(text)
    sys.stdout.flush()
    sys.exit(0)

sys.exit(1)
