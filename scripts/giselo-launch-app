#!/home/jesusu/Workspace/agents/crowia/.venv/bin/python3
"""
giselo-launch-app <binary> [window_name]
Raises existing window if app already running, otherwise launches it.
window_name is the title fragment for wmctrl (defaults to binary name).
"""
import os
import pathlib
import shutil
import subprocess
import sys


def main():
    if len(sys.argv) < 2:
        print("Uso: giselo-launch-app <binary> [window_name]")
        sys.exit(1)

    binary      = sys.argv[1]
    window_name = sys.argv[2] if len(sys.argv) > 2 else binary

    result = subprocess.run(["pgrep", "-x", binary], capture_output=True)
    if result.returncode == 0:
        raised = False
        try:
            r = subprocess.run(["wmctrl", "-a", window_name],
                               capture_output=True, timeout=3)
            raised = r.returncode == 0
        except (FileNotFoundError, subprocess.TimeoutExpired):
            pass
        if raised:
            print(f"'{binary}' ya estaba corriendo — ventana enfocada.")
        else:
            print(f"'{binary}' ya está corriendo.")
        return

    full_path = shutil.which(binary) or binary
    uid = os.getuid()
    env = os.environ.copy()
    env.setdefault("WAYLAND_DISPLAY", "wayland-0")
    env.setdefault("DISPLAY", ":0")
    env.setdefault("XDG_RUNTIME_DIR", f"/run/user/{uid}")
    env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")
    try:
        subprocess.Popen(
            [full_path],
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            env=env,
        )
        print(f"'{binary}' iniciado.")
    except Exception as e:
        print(f"Error al lanzar '{binary}': {e}")
        sys.exit(1)


if __name__ == "__main__":
    main()
