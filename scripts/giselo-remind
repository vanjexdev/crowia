#!/home/jesusu/Workspace/agents/crowia/.venv/bin/python3
"""
giselo-remind <acción> [args]

Acciones:
  add "mensaje" "cuando" [--calendar]   Crear recordatorio
  list                                   Listar recordatorios activos
  cancel <id>                            Cancelar recordatorio

Formato de "cuando":
  "2026-05-15 14:00"          → Una sola vez en esa fecha/hora
  "hourly"                    → Cada hora (en punto)
  "daily 09:00"               → Todos los días a las 9am
  "weekly Mon 09:00"          → Todos los lunes a las 9am
  "weekly Mon,Wed,Fri 18:00"  → Varios días a las 6pm

Opciones:
  --calendar   También crear evento en Google Calendar
"""
import json
import os
import pathlib
import shlex
import subprocess
import sys
import time

from dateutil import parser as dtparser

REMINDERS_FILE  = pathlib.Path.home() / ".config/crowia/reminders.json"
SYSTEMD_DIR     = pathlib.Path.home() / ".config/systemd/user"
FIRE_SCRIPT     = pathlib.Path(__file__).parent / "giselo-remind-fire"
GOOGLE_SCRIPT   = pathlib.Path(__file__).parent / "giselo-google"

DAY_MAP = {
    "lun": "Mon", "mon": "Mon",
    "mar": "Tue", "tue": "Tue",
    "mié": "Wed", "mie": "Wed", "wed": "Wed",
    "jue": "Thu", "thu": "Thu",
    "vie": "Fri", "fri": "Fri",
    "sáb": "Sat", "sab": "Sat", "sat": "Sat",
    "dom": "Sun", "sun": "Sun",
}


def load() -> list:
    if REMINDERS_FILE.exists():
        try:
            return json.loads(REMINDERS_FILE.read_text(encoding="utf-8"))
        except Exception:
            pass
    return []


def save(reminders: list):
    REMINDERS_FILE.parent.mkdir(parents=True, exist_ok=True)
    REMINDERS_FILE.write_text(json.dumps(reminders, indent=2, ensure_ascii=False))


def make_id() -> str:
    return f"giselo-remind-{int(time.time())}"


def parse_when(when_str: str) -> tuple[str, bool, str]:
    """Returns (systemd_calendar, is_recurring, human_description)."""
    low = when_str.lower().strip()

    if low in ("hourly", "cada hora", "every hour"):
        return "*-*-* *:00:00", True, "cada hora"

    if low.startswith("daily") or low.startswith("diario") or low.startswith("todos los días") or low.startswith("todos los dias"):
        time_part = low
        for prefix in ("daily", "diario", "todos los días", "todos los dias", "at", "a las", "a"):
            time_part = time_part.replace(prefix, "").strip()
        if time_part:
            t = dtparser.parse(time_part).strftime("%H:%M:%S")
        else:
            t = "09:00:00"
        return f"*-*-* {t}", True, f"diario a las {t[:5]}"

    if low.startswith("weekly") or low.startswith("semanal"):
        rest = low.replace("weekly", "").replace("semanal", "").strip()
        # parse day(s): "Mon 09:00" or "Mon,Wed,Fri 18:00"
        parts = rest.split()
        if not parts:
            return "Mon *-*-* 09:00:00", True, "lunes a las 09:00"
        days_raw = parts[0].split(",")
        en_days = ",".join(DAY_MAP.get(d[:3].lower(), d) for d in days_raw)
        time_part = " ".join(parts[1:]) if len(parts) > 1 else "09:00"
        t = dtparser.parse(time_part).strftime("%H:%M:%S")
        return f"{en_days} *-*-* {t}", True, f"{en_days} a las {t[:5]}"

    # One-shot datetime
    dt = dtparser.parse(when_str, dayfirst=False)
    return dt.strftime("%Y-%m-%d %H:%M:%S"), False, dt.strftime("%Y-%m-%d %H:%M")


def schedule_one_shot(rem_id: str, message: str, systemd_cal: str):
    subprocess.run([
        "systemd-run", "--user",
        f"--on-calendar={systemd_cal}",
        f"--unit={rem_id}",
        f"--description=Giselo: {message}",
        str(FIRE_SCRIPT), message,
    ], check=True, capture_output=True)


def schedule_recurring(rem_id: str, message: str, systemd_cal: str):
    SYSTEMD_DIR.mkdir(parents=True, exist_ok=True)
    safe_msg = shlex.quote(message)

    service = SYSTEMD_DIR / f"{rem_id}.service"
    service.write_text(f"""[Unit]
Description=Giselo Reminder: {message}

[Service]
Type=oneshot
ExecStart={FIRE_SCRIPT} {safe_msg}
Environment=DISPLAY=:0
Environment=WAYLAND_DISPLAY=wayland-0
Environment=XDG_RUNTIME_DIR=/run/user/{os.getuid()}
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/{os.getuid()}/bus
""")

    timer = SYSTEMD_DIR / f"{rem_id}.timer"
    timer.write_text(f"""[Unit]
Description=Giselo Reminder Timer: {message}

[Timer]
OnCalendar={systemd_cal}
Persistent=true

[Install]
WantedBy=timers.target
""")

    subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)
    subprocess.run(["systemctl", "--user", "enable", "--now", f"{rem_id}.timer"], check=True)


def cancel_reminder(rem_id: str, is_recurring: bool):
    if is_recurring:
        subprocess.run(["systemctl", "--user", "disable", "--now", f"{rem_id}.timer"],
                       capture_output=True)
        for ext in (".service", ".timer"):
            f = SYSTEMD_DIR / f"{rem_id}{ext}"
            f.unlink(missing_ok=True)
        subprocess.run(["systemctl", "--user", "daemon-reload"], capture_output=True)
    else:
        subprocess.run(["systemctl", "--user", "stop", f"{rem_id}.timer"],
                       capture_output=True)


def cmd_add(args: list):
    if len(args) < 2:
        print("Uso: giselo-remind add \"mensaje\" \"cuando\"", file=sys.stderr)
        sys.exit(1)

    add_calendar = "--calendar" in args
    args = [a for a in args if a != "--calendar"]

    message = args[0]
    when_str = " ".join(args[1:])

    try:
        systemd_cal, is_recurring, description = parse_when(when_str)
    except Exception as e:
        print(f"Error parseando fecha '{when_str}': {e}", file=sys.stderr)
        sys.exit(1)

    rem_id = make_id()

    try:
        if is_recurring:
            schedule_recurring(rem_id, message, systemd_cal)
        else:
            schedule_one_shot(rem_id, message, systemd_cal)
    except subprocess.CalledProcessError as e:
        print(f"Error al agendar con systemd: {e}", file=sys.stderr)
        sys.exit(1)

    reminder = {
        "id": rem_id,
        "message": message,
        "when": when_str,
        "systemd_calendar": systemd_cal,
        "description": description,
        "recurring": is_recurring,
    }
    reminders = load()
    reminders.append(reminder)
    save(reminders)

    print(f"Recordatorio creado: '{message}' — {description} (id: {rem_id})")

    if add_calendar and GOOGLE_SCRIPT.exists():
        try:
            subprocess.run([str(GOOGLE_SCRIPT), "calendar", "add", message, when_str],
                           timeout=30)
        except Exception:
            pass


def cmd_list():
    reminders = load()
    if not reminders:
        print("Sin recordatorios activos.")
        return
    for r in reminders:
        rtype = "↻ recurrente" if r.get("recurring") else "→ una vez"
        print(f"[{r['id']}] {r['message']} — {r['description']} ({rtype})")


def cmd_cancel(args: list):
    if not args:
        print("Uso: giselo-remind cancel <id>", file=sys.stderr)
        sys.exit(1)
    rem_id = args[0]
    reminders = load()
    match = next((r for r in reminders if r["id"] == rem_id or rem_id in r["id"]), None)
    if not match:
        print(f"Recordatorio '{rem_id}' no encontrado.")
        sys.exit(1)
    cancel_reminder(match["id"], match.get("recurring", False))
    reminders = [r for r in reminders if r["id"] != match["id"]]
    save(reminders)
    print(f"Recordatorio cancelado: '{match['message']}'")


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    action = args[0].lower()
    rest = args[1:]

    if action == "add":
        cmd_add(rest)
    elif action == "list":
        cmd_list()
    elif action in ("cancel", "delete", "remove"):
        cmd_cancel(rest)
    else:
        print(f"Acción desconocida: '{action}'")
        sys.exit(1)


if __name__ == "__main__":
    main()
