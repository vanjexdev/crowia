#!/usr/bin/env python3
"""
giselo-activate-profile [nombre]
Activa un perfil de trabajo: lanza el navegador configurado y reporta el contexto.
Sin argumentos: lista perfiles disponibles.
"""
import json
import os
import pathlib
import shutil
import subprocess
import sys

CONFIG_FILE = pathlib.Path(__file__).resolve().parent.parent / "config.yaml"
STATE_FILE  = pathlib.Path("/tmp/crowia/active_profile.json")


def read_profiles() -> dict:
    try:
        import yaml
        cfg = yaml.safe_load(CONFIG_FILE.read_text(encoding="utf-8"))
        return cfg.get("profiles", {})
    except Exception as e:
        print(f"Error leyendo config: {e}", file=sys.stderr)
        return {}


def main():
    profiles = read_profiles()

    if len(sys.argv) < 2:
        if not profiles:
            print("No hay perfiles configurados en config.yaml.")
        else:
            print("Perfiles disponibles:")
            for name, p in profiles.items():
                browser = p.get("browser", "—")
                print(f"  {name}: navegador={browser}")
        return

    name = sys.argv[1].strip().lower()
    match = next((k for k in profiles if k.lower() == name), None)
    if not match:
        available = ", ".join(profiles.keys()) if profiles else "(ninguno)"
        print(f"Perfil '{name}' no encontrado. Disponibles: {available}")
        sys.exit(1)

    profile = profiles[match]
    browser = profile.get("browser", "")
    context = profile.get("context", "")

    pathlib.Path("/tmp/crowia").mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps({"name": match, "browser": browser, "context": context}))

    if browser:
        binary = shutil.which(browser) or browser
        uid = os.getuid()
        env = os.environ.copy()
        env.setdefault("WAYLAND_DISPLAY", "wayland-0")
        env.setdefault("DISPLAY", ":0")
        env.setdefault("XDG_RUNTIME_DIR", f"/run/user/{uid}")
        env.setdefault("DBUS_SESSION_BUS_ADDRESS", f"unix:path=/run/user/{uid}/bus")
        try:
            subprocess.Popen(
                [binary],
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                env=env,
            )
            print(f"Perfil '{match}' activado. Navegador '{browser}' iniciado.")
        except Exception as e:
            print(f"Perfil '{match}' activado. No se pudo lanzar '{browser}': {e}")
    else:
        print(f"Perfil '{match}' activado.")

    if context:
        print(f"Contexto: {context}")


if __name__ == "__main__":
    main()
